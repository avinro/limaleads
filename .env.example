# ─────────────────────────────────────────────
# Apollo.io
# ─────────────────────────────────────────────
# Master API key — required for /mixed_people/api_search (regular key returns 403)
APOLLO_API_KEY=your_apollo_master_api_key_here

# How often the Apollo poller runs (in hours). Default: 4
APOLLO_POLL_INTERVAL_HOURS=4

# JSON object of Apollo search filter params — see docs/apollo-api-spike.md §3 for all options.
# Example targeting senior decision-makers in Spain:
# {"person_titles":["CEO","Founder","Co-Founder"],"person_seniorities":["owner","founder","c_suite"],"organization_locations":["Spain"]}
APOLLO_SOURCE_CRITERIA={"person_titles":["CEO"],"person_seniorities":["owner","founder","c_suite"]}

# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# ─────────────────────────────────────────────
# Google Gmail OAuth 2.0
# ─────────────────────────────────────────────
GMAIL_CLIENT_ID=your_google_oauth_client_id_here
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret_here
# Run `npm run gmail:auth` to generate this token
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token_here

# ─────────────────────────────────────────────
# Google Gemini
# ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────────
# Slack
# ─────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ─────────────────────────────────────────────
# Admin API
# ─────────────────────────────────────────────
# Secret token for POST /admin/leads/:id/status — generate with: openssl rand -hex 32
ADMIN_API_TOKEN=your_admin_api_token_here
